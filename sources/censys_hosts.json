{
    "name": "censys_hosts",
    "category": "scanners",
    "endpoint": "https://search.censys.io/api/v2/hosts/search?q={target}",
    "method": "GET",
    "requires_auth": true,
    "selectors": {
        "results": "$.result.hits[*].ip"
    },
    "rate_limit": 1.0,
    "headers": {
        "Authorization": "Basic {CENSYS_AUTH_BASE64}"
    },
    "api_key_slots": [
        "{CENSYS_AUTH_BASE64}"
    ],
    "input_type": "domain",
    "output_type": [
        "ip"
    ],
    "normalization_map": {
        "ip": "ip_address"
    },
    "tags": [
        "passive",
        "infrastructure"
    ],
    "health_check_url": "https://search.censys.io",
    "expected_status": 200,
    "reliability_score": 5,
    "backup_endpoints": [],
    "confidence": 1.0
}